<?xml version="1.0" encoding="utf-8"?>
<!--
  Local development: resolves KoreForge.Kafka from local build artifacts.
  Run bin/build-kafka.ps1 (or dotnet pack in KoreForge.Kafka) to refresh.
-->
<configuration>
  <packageSources>
    <add key="KoreForge.Kafka.local" value="../../KoreForge.Kafka/artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
